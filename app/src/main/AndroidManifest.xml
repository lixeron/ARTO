<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================
         PERMISSIONS
         ============================================================ -->

    <!-- SMS: Receive and read incoming text messages -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Contacts: Look up sender to filter known contacts -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Phone: Required for CallScreeningService and caller ID -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- Network: Send sanitized text to Anthropic API / Supabase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Notifications: Alert user about detected spam -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ============================================================
         APPLICATION
         ============================================================ -->

    <application
        android:name=".ArtoApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ARTO"
        tools:targetApi="34">

        <!-- Main Activity (Jetpack Compose entry point) -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ARTO">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ========================================================
             CALL SCREENING SERVICE
             The OS routes incoming calls here. Requires the user to
             set Arto as their default Caller ID & Spam app.
             ======================================================== -->
        <service
            android:name=".service.ArtoCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!-- ========================================================
             SMS BROADCAST RECEIVER
             Listens for incoming SMS. High priority ensures we get
             the broadcast before the default SMS app.
             ======================================================== -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>